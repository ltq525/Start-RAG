# LLM provider settings
# Use either the generic LLM_* variables or provider-specific variables.
LLM_MODEL_ID=
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=60

# Optional provider-specific keys
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
MODELSCOPE_API_KEY=
KIMI_API_KEY=
MOONSHOT_API_KEY=
ZHIPU_API_KEY=
GLM_API_KEY=

# Local/OpenAI-compatible providers
# Example: OLLAMA_API_KEY=ollama, OLLAMA_HOST=http://localhost:11434/v1
# Example: VLLM_API_KEY=vllm, VLLM_HOST=http://localhost:8000/v1
OLLAMA_API_KEY=
OLLAMA_HOST=
VLLM_API_KEY=
VLLM_HOST=

# Xiaomi MiMo compatibility used by my_llm.py and Q&A_Assistant.py
MIMO_API_KEY=
MIMO_BASE_URL=
MIMO_MODEL_ID=

# Search tools
TAVILY_API_KEY=
SERPAPI_API_KEY=
GOOGLE_SEARCH_HL=zh-cn
GOOGLE_SEARCH_GL=cn

# Qdrant vector database
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=hello_agents_vectors
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine
QDRANT_TIMEOUT=30

# Neo4j graph database
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=60
AURA_INSTANCEID=
AURA_INSTANCENAME=

# Embedding provider
EMBED_MODEL_TYPE=dashscope
EMBED_MODEL_NAME=text-embedding-v3
EMBED_API_KEY=
EMBED_BASE_URL=
EMBED_DIMENSION=1024
EMBED_RES_LEVEL=1

# Gradio app
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
